{
	"name": "client",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"start:dev": "vite dev",
		"start:build": "vite build",
		"start:preview": "vite preview",
		"start:prepare": "svelte-kit sync || echo ''",
		"start:check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"start:check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"start:format": "prettier --write .",
		"start:lint": "prettier --check . && eslint .",
		"start:test:unit": "vitest",
		"start:test": "npm run test:unit -- --run",
		"start:storybook": "storybook dev -p 6006",
		"start:build-storybook": "storybook build"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^4.1.1",
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.37.0",
		"@inlang/paraglide-js": "^2.4.0",
		"@storybook/addon-a11y": "^9.1.11",
		"@storybook/addon-docs": "^9.1.11",
		"@storybook/addon-svelte-csf": "^5.0.10",
		"@storybook/addon-vitest": "^9.1.11",
		"@storybook/sveltekit": "^9.1.11",
		"@sveltejs/adapter-auto": "^6.1.1",
		"@sveltejs/kit": "^2.47.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/vite": "^4.1.14",
		"@types/node": "^22.18.10",
		"@vitest/browser": "^3.2.4",
		"eslint": "^9.37.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^9.1.11",
		"eslint-plugin-svelte": "^3.12.4",
		"globals": "^16.4.0",
		"playwright": "^1.56.0",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"storybook": "^9.1.11",
		"svelte": "^5.40.1",
		"svelte-check": "^4.3.3",
		"tailwindcss": "^4.1.14",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.46.1",
		"vite": "^7.1.10",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^3.2.4",
		"vitest-browser-svelte": "^0.1.0"
	},
	"dependencies": {
		"@tailwindcss/forms": "^0.5.10",

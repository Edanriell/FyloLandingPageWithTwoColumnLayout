{
	"name": "client",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"start:dev": "vite dev",
		"start:build": "vite build",
		"start:preview": "vite preview",
		"start:prepare": "svelte-kit sync || echo ''",
		"start:check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"start:check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"start:format": "prettier --write .",
		"start:lint": "prettier --check . && eslint .",
		"start:test:unit": "vitest",
		"start:test": "npm run test:unit -- --run",
		"start:storybook": "storybook dev -p 6006",
		"start:build-storybook": "storybook build"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^4.1.1",
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.22.0",
		"@inlang/paraglide-js": "^2.0.0",
		"@storybook/addon-a11y": "^9.1.6",
		"@storybook/addon-docs": "^9.1.6",
		"@storybook/addon-svelte-csf": "^5.0.8",
		"@storybook/addon-vitest": "^9.1.6",
		"@storybook/sveltekit": "^9.1.6",
		"@sveltejs/adapter-auto": "^6.0.0",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"@tailwindcss/vite": "^4.0.0",
		"@types/node": "^22",
		"@vitest/browser": "^3.2.3",
		"eslint": "^9.22.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-storybook": "^9.1.6",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^16.0.0",
		"playwright": "^1.53.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"storybook": "^9.1.6",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.20.0",
		"vite": "^7.0.4",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^3.2.3",
		"vitest-browser-svelte": "^0.1.0"
	},
	"dependencies": {
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.18",
		"less": "^4.4.1"
	}
}
